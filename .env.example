# Optional development overrides for the bundled multitenant public-client app.
# Packaged builds should ship a real client ID in src/main/auth/app-registration.ts.
# The Entra app registration must include the Mobile and desktop redirect URI http://localhost.
# MSAL_CLIENT_ID=your-app-client-id
# MSAL_AUTHORITY=https://login.microsoftonline.com/organizations
GRAPH_SCOPES=openid profile offline_access User.Read Calendars.ReadWrite MailboxSettings.Read Contacts.Read
SYNC_LOOKAHEAD_DAYS=90
SYNC_LOOKBEHIND_DAYS=30
SYNC_INTERVAL_MINUTES=5
