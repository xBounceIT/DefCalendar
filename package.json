{
  "name": "defcalendar",
  "version": "0.3.4",
  "description": "Desktop calendar app for Microsoft 365 Exchange Online built with Electron.",
  "author": "Daniel",
  "main": "out/main/index.cjs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:publish": "electron-vite build && electron-builder --publish always",
    "lint": "oxlint --tsconfig tsconfig.json src test electron.vite.config.ts",
    "lint:fix": "oxlint --tsconfig tsconfig.json --fix src test electron.vite.config.ts",
    "format": "oxfmt --write src test electron.vite.config.ts",
    "format:check": "oxfmt --check src test electron.vite.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.daniel.defcalendar",
    "productName": "DefCalendar",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xBounceIT",
        "repo": "DefCalendar",
        "releaseType": "draft"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@tanstack/react-query": "^5.96.1",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "delay": "^7.0.0",
    "dotenv": "^17.4.0",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.4",
    "html-to-text": "^9.0.5",
    "i18next": "^26.0.3",
    "pathe": "^2.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.2",
    "electron-vite": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "@electron/asar": "^4.1.1",
    "@electron/universal": "^3.0.3",
    "brace-expansion": "^5.0.5",
    "dir-compare": "^5.0.0",
    "ejs": "^3.1.10",
    "filelist": "^2.0.1",
    "glob": "^13.0.6",
    "jake": "^11.9.5",
    "minimatch": "^10.2.4",
    "node-gyp": "^12.2.0",
    "rimraf": "^6.1.3",
    "temp": "^0.9.4"
  }
}
